# Copy to .env and fill in. Never commit .env.

# --- GCP / Vertex AI ---
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=true
# Local dev only; on Cloud Run use the runtime service account.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa-key.json

# --- MongoDB Atlas ---
# Use any M10+ Atlas cluster — vector search isn't available on M0/shared.
# See SETUP.md for cluster provisioning instructions.
MONGODB_URI=mongodb+srv://USER:PASS@cluster0.example.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=adk_demo

# --- Vector index ---
PRODUCTS_COLLECTION=products
PRODUCTS_VECTOR_INDEX=products_vector_index

# --- Voyage AI (Atlas Embedding & Reranking API) ---
# Model API key from Atlas Project -> AI Models -> Model API Keys.
VOYAGE_API_KEY=al-your-atlas-model-api-key
VOYAGE_API_URL=https://ai.mongodb.com/v1/embeddings
EMBEDDING_MODEL=voyage-4-large

# --- Sessions / memory collections (MongoDB-only persistence) ---
SESSIONS_COLLECTION=sessions
MEMORY_COLLECTION=memory
ARTIFACTS_COLLECTION=artifacts

# --- Agent runtime ---
GEMINI_MODEL=gemini-2.5-flash
APP_NAME=grocery_assistant
LOG_LEVEL=INFO
